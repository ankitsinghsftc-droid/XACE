# Copy this file to .env and fill in your values
# NEVER commit .env — it is in .gitignore

# Anthropic API key — required for Prompt Intelligence Layer
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# XACE Runtime connection settings
XACE_RUNTIME_HOST=localhost
XACE_RUNTIME_PORT=7777

# Log level: debug | info | warn | error
XACE_LOG_LEVEL=info

# Determinism guard mode: STRICT | DEV | SILENT
XACE_DETERMINISM_MODE=STRICT

# Schema version
XACE_SCHEMA_VERSION=1.0.0
